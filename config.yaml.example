# ============================================
# Zundamon 投資ニュースコンシェルジュ 設定
# ============================================
# このファイルを config.yaml にコピーして自分好みに編集してください。
# Python の知識は必要ありません。ブラウザ上の GitHub UI からでも編集可能です。

# --------------------------------------------
# モード: beginner / expert / hybrid
#   beginner : 用語解説つきで丁寧に説明 (投資初心者向け)
#   expert   : プロ向けに要点だけを簡潔に
#   hybrid   : 両方のバランス型 (初期設定のおすすめ)
# --------------------------------------------
mode: hybrid

# --------------------------------------------
# 配信時刻のメモ (実際の配信は .github/workflows/daily.yml の cron が決定)
# デフォルトは 1 日 2 回: 朝 06:00 JST + 夕 19:00 JST
# 配信時刻を変えたい場合は daily.yml の cron 行を編集してください。
# --------------------------------------------
delivery_time_jst: "06:00, 19:00"

# --------------------------------------------
# 使用するAI ("gemini" or "claude")
#   gemini : Google Gemini Flash (無料枠あり・推奨)
#   claude : Anthropic Claude Haiku (高品質・有料)
# --------------------------------------------
ai_provider: gemini

# --------------------------------------------
# 配信先メールアドレス (オプション)
# Gmail に届けたい場合のみ設定。
# Discord 通知のみで OK な人は空欄 ("") のままで構いません。
# 両方設定すれば両方に届きます。
#
# 別途 GitHub Secrets に以下も登録する必要あり:
#   GMAIL_FROM         : 送信元 Gmail アドレス
#   GMAIL_APP_PASSWORD : Gmail アプリパスワード (16桁、myaccount.google.com/apppasswords)
# --------------------------------------------
email_to: ""

# --------------------------------------------
# 保有銘柄 (ティッカーと銘柄名をセットで書いて)
# 日本株の場合はティッカーに証券コード (例: 7203) を入れてください。
# --------------------------------------------
holdings:
  - ticker: NVDA
    name: エヌビディア
  - ticker: AAPL
    name: アップル
  - ticker: MSFT
    name: マイクロソフト
  # ↓ あなたの保有銘柄を追記してください
  # - ticker: 7203
  #   name: トヨタ自動車

# --------------------------------------------
# 興味分野 (キーワードで指定)
# ここに書いたキーワードを含む記事は優先して届きます。
# --------------------------------------------
interests:
  - S&P500
  - 新NISA
  - 半導体
  - AI
  - 円安
  - 金利

# --------------------------------------------
# 避けたいトピック (ニュースから除外)
# --------------------------------------------
exclude:
  - 仮想通貨
  - IPO

# --------------------------------------------
# 配信記事数の上限
# --------------------------------------------
limits:
  top_count: 3         # 必読セクションの記事数
  notable_count: 7     # その他注目セクションの記事数

# --------------------------------------------
# 🎯 買い増しシグナル (オプション)
# --------------------------------------------
# 「冷静なときに事前設定したルール」を書いておくと、
# 該当銘柄の終値が target_below を下回った日に、ダイジェストの冒頭に
# 「ルール発動: NVDA が設定ライン $110 を下回りました」と通知されます。
#
# 価格データは Yahoo Finance (yfinance) から無料取得。日本株は ticker に
# `.T` を付けてください (例: 7203.T = トヨタ自動車)。
#
# ⚠️ これは投資助言ではありません。あなた自身が冷静に決めたルールが
#   満たされたことを通知するだけです。判断は必ずご自身で。
#
# 不要なら buy_signals: [] か、このブロックごと削除して構いません。
buy_signals: []
# 例:
# buy_signals:
#   - ticker: NVDA
#     target_below: 110.0
#     note: "本格買い増しライン"
#   - ticker: 7203.T
#     target_below: 2500
#     note: "押し目"

# --------------------------------------------
# 上級者向け調整 (通常はいじらなくてOK)
# --------------------------------------------
advanced:
  # 関連度スコア (0-10) の閾値
  score_threshold_top: 7       # これ以上で「必読」
  score_threshold_notable: 5   # これ以上で「その他注目」
  # 何時間前までの記事を対象にするか
  lookback_hours: 24
